        "eslint-plugin-perfectionist": "^5.7.0",
        "obsidian": "latest",
        "oxlint": "^1.57.0",
        "prettier": "^3.8.1",
        "typescript": "5.9.2",
        "vite": "^8.0.2",
        "vitest": "^4.1.1"
    },
    "dependencies": {
